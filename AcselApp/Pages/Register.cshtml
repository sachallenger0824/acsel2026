@page "{type?}"
@model AcselApp.Pages.RegisterModel
@{
    Layout = null;
    var pType = Model.ParticipantType; // "International" or "Domestic"
    var isDomestic = pType == "Domestic";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Registration | ACSEL 2026</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@1,600&family=IBM+Plex+Mono&family=Outfit:wght@400;600&family=Plus+Jakarta+Sans:wght@400;700&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined" rel="stylesheet">
    <link rel="stylesheet" href="~/style.css">
</head>
<body>
    <svg class="noise-overlay" viewBox="0 0 100 100" preserveAspectRatio="none">
        <filter id="noiseFilter">
            <feTurbulence type="fractalNoise" baseFrequency="0.8" numOctaves="3" stitchTiles="stitch" />
        </filter>
        <rect width="100%" height="100%" filter="url(#noiseFilter)" opacity="0.05" />
    </svg>

    <nav class="navbar" id="navbar">
        <div class="nav-container">
            <a href="~/" class="logo">ACSEL 2026</a>
            <input type="checkbox" id="nav-toggle" class="nav-toggle-checkbox">
            <label for="nav-toggle" class="nav-toggle-label">
                <span class="material-symbols-outlined menu-icon">menu</span>
                <span class="material-symbols-outlined close-icon">close</span>
            </label>
            <div class="nav-menu">
                <a href="~/about.html" class="nav-link">About</a>
                <a href="~/programme.html" class="nav-link">Programme</a>
                <a href="~/speakers.html" class="nav-link">Speakers</a>
                <a href="~/travel.html" class="nav-link">Travel</a>
                <a href="~/sponsorship.html" class="nav-link">Sponsorship</a>
                <a href="~/submit.html" class="nav-link" style="white-space:nowrap;">Submit Paper</a>
                <div class="nav-register-wrapper">
                    <a href="~/Register" class="btn btn-accent nav-cta">
                        <span class="btn-bg"></span>
                        <span class="btn-text">Register</span>
                    </a>
                    <div class="register-dropdown">
                        <div class="register-dropdown-inner">
                            <a href="~/Register/International" class="register-dropdown-item">🌍 International Participants</a>
                            <a href="~/Register/Domestic" class="register-dropdown-item"><img src="https://flagcdn.com/w40/tw.png" alt="TW" style="width:20px;height:14px;vertical-align:middle;margin-right:4px;">Domestic Participants (Taiwan)</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </nav>

    <section class="hero subpage-hero section-dark">
        <div class="hero-bg"></div>
        <div class="hero-gradient"></div>
        <div class="container hero-container" style="padding-top: 15vh;">
            <div class="hero-content">
                <h1 class="hero-title animate-item">
                    <span class="hero-serif">Registration</span>
                </h1>
            </div>
        </div>
    </section>

    <section id="register" class="registration-section container py-fluid pb-xxl">
        @if (isDomestic)
        {
            <div class="text-center mb-xl animate-on-scroll">
                <h2 style="font-size: 1.5rem; font-weight: 700; margin-bottom: 0.75rem;">歡迎報名 ACSEL 2026</h2>
                <p style="opacity: 0.75; max-width: 600px; margin: 0 auto;">本報名類別適用於台灣地區與會者，費用以新台幣（TWD）計算</p>
            </div>
        }
        else
        {
            <div class="text-center mb-xl animate-on-scroll">
                <h2 style="font-size: 1.5rem; font-weight: 700; margin-bottom: 0.75rem;">Welcome to ACSEL 2026</h2>
                <p style="opacity: 0.75; max-width: 700px; margin: 0 auto 0.5rem;">This registration category is intended for participants outside Taiwan.<br>All registration fees are listed and payable in New Taiwan Dollars (TWD).</p>
                <p style="opacity: 0.6; font-size: 0.9rem; max-width: 600px; margin: 0 auto;">Please note that exchange rates may vary depending on your payment provider.</p>
            </div>
        }

        @if (!string.IsNullOrEmpty(Model.SuccessMessage))
        {
            <div class="animate-on-scroll" style="background: rgba(40, 167, 69, 0.15); border: 1px solid rgba(40, 167, 69, 0.4); padding: 1.5rem; border-radius: 1rem; text-align: center; margin-bottom: 2rem; color: #28a745;">
                <span class="material-symbols-outlined" style="vertical-align: middle;">check_circle</span>
                <strong>@Model.SuccessMessage</strong>
            </div>
        }

        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="animate-on-scroll" style="background: rgba(220, 53, 69, 0.15); border: 1px solid rgba(220, 53, 69, 0.4); padding: 1.5rem; border-radius: 1rem; text-align: center; margin-bottom: 2rem; color: #dc3545;">
                <span class="material-symbols-outlined" style="vertical-align: middle;">error</span>
                <strong>@Model.ErrorMessage</strong>
            </div>
        }

        <div class="pricing-grid animate-on-scroll">
            @if (isDomestic)
            {
                <div class="pricing-card">
                    <h3>早鳥優惠</h3>
                    <p class="ends data-text">2026年8月15日前</p>
                    <div class="price">4,000 <span class="currency">TWD</span></div>
                    <p class="tier">一般</p>
                </div>
                <div class="pricing-card featured">
                    <h3>標準</h3>
                    <p class="ends data-text">2026年8月15日後</p>
                    <div class="price">4,500 <span class="currency">TWD</span></div>
                    <p class="tier">一般</p>
                </div>
                <div class="pricing-card">
                    <h3>學生</h3>
                    <p class="ends data-text">需出示有效學生證</p>
                    <div class="price">1,500 <span class="currency">TWD</span></div>
                    <p class="tier">學生（早鳥／標準）</p>
                </div>
            }
            else
            {
                <div class="pricing-card">
                    <h3>Early Bird</h3>
                    <p class="ends data-text">Ends 15 August 2026</p>
                    <div class="price">6,000 <span class="currency">TWD</span></div>
                    <p class="tier">Standard</p>
                </div>
                <div class="pricing-card featured">
                    <h3>Standard</h3>
                    <p class="ends data-text">After 15 August 2026</p>
                    <div class="price">7,500 <span class="currency">TWD</span></div>
                    <p class="tier">Standard</p>
                </div>
                <div class="pricing-card">
                    <h3>Student</h3>
                    <p class="ends data-text">Valid Student ID Required</p>
                    <div class="price">3,000 <span class="currency">TWD</span></div>
                    <p class="tier">Student (Early / Standard)</p>
                </div>
            }
        </div>
    </section>

    <!-- Registration Form Section -->
    <section class="container pb-xxl" style="padding-top: 0; max-width: 720px;">
        <div class="animate-on-scroll">
            <h2 style="font-size: 1.75rem; font-weight: 700; margin-bottom: 0.5rem;">@(isDomestic ? "報名表單" : "Registration Form")</h2>
            <p style="opacity: 0.65; margin-bottom: 2.5rem;">@(isDomestic ? "請填寫以下所有必填欄位以完成報名。" : "Please fill in all required fields to complete your registration.")</p>

            <form id="registrationForm" method="post" novalidate
                style="display: flex; flex-direction: column; gap: 1.5rem;">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Registration.ParticipantType" value="@pType" />

                <!-- Section 1: Personal Information -->
                <fieldset style="border: 1px solid rgba(0,0,0,0.12); border-radius: 0.75rem; padding: 1.5rem; margin: 0;">
                    <legend style="font-weight: 700; padding: 0 0.5rem; font-size: 0.875rem; letter-spacing: 0.05em; text-transform: uppercase; opacity: 0.6;">@(isDomestic ? "個人資料" : "Personal Information")</legend>

                    <div style="display: flex; flex-direction: column; gap: 0.4rem; margin-bottom: 1rem;">
                        <label asp-for="Registration.FullName" style="font-size: 0.875rem; font-weight: 600;">@(isDomestic ? "姓名" : "Full Name (First / Last)") <span style="color:#e53e3e;">*</span></label>
                        <input type="text" asp-for="Registration.FullName" required autocomplete="name"
                            placeholder="@(isDomestic ? "姓名" : "Full Name")"
                            style="padding: 0.65rem 0.875rem; border: 1px solid rgba(0,0,0,0.18); border-radius: 0.5rem; font-size: 0.95rem; font-family: inherit; outline: none; transition: border-color 0.2s; background: transparent; width: 100%; box-sizing: border-box;">
                        <span asp-validation-for="Registration.FullName" style="color:#e53e3e; font-size: 0.8rem; margin-top: 0.2rem;"></span>
                    </div>

                    <div style="display: flex; flex-direction: column; gap: 0.4rem; margin-bottom: 1rem;">
                        <label asp-for="Registration.Email" style="font-size: 0.875rem; font-weight: 600;">@(isDomestic ? "電子郵件" : "Email Address") <span style="color:#e53e3e;">*</span></label>
                        <input type="email" asp-for="Registration.Email" required autocomplete="email"
                            placeholder="your@email.com"
                            style="padding: 0.65rem 0.875rem; border: 1px solid rgba(0,0,0,0.18); border-radius: 0.5rem; font-size: 0.95rem; font-family: inherit; outline: none; transition: border-color 0.2s; background: transparent; width: 100%; box-sizing: border-box;">
                        <span asp-validation-for="Registration.Email" style="color:#e53e3e; font-size: 0.8rem; margin-top: 0.2rem;"></span>
                    </div>

                    <div style="display: flex; flex-direction: column; gap: 0.4rem; margin-bottom: 1rem;">
                        <label asp-for="Registration.Institution" style="font-size: 0.875rem; font-weight: 600;">@(isDomestic ? "服務單位／機構" : "Affiliation / Organization") <span style="color:#e53e3e;">*</span></label>
                        <input type="text" asp-for="Registration.Institution" required autocomplete="organization"
                            placeholder="@(isDomestic ? "服務單位或機構名稱" : "Institution or organization name")"
                            style="padding: 0.65rem 0.875rem; border: 1px solid rgba(0,0,0,0.18); border-radius: 0.5rem; font-size: 0.95rem; font-family: inherit; outline: none; transition: border-color 0.2s; background: transparent; width: 100%; box-sizing: border-box;">
                        <span asp-validation-for="Registration.Institution" style="color:#e53e3e; font-size: 0.8rem; margin-top: 0.2rem;"></span>
                    </div>

                    <div style="display: flex; flex-direction: column; gap: 0.4rem; margin-bottom: 1rem;">
                        <label asp-for="Registration.TitlePosition" style="font-size: 0.875rem; font-weight: 600;">@(isDomestic ? "職稱" : "Title / Position") <span style="color:#e53e3e;">*</span></label>
                        <input type="text" asp-for="Registration.TitlePosition" required
                            placeholder="@(isDomestic ? "例如：教授、研究員、學生" : "e.g. Professor, Researcher, Student")"
                            style="padding: 0.65rem 0.875rem; border: 1px solid rgba(0,0,0,0.18); border-radius: 0.5rem; font-size: 0.95rem; font-family: inherit; outline: none; transition: border-color 0.2s; background: transparent; width: 100%; box-sizing: border-box;">
                        <span asp-validation-for="Registration.TitlePosition" style="color:#e53e3e; font-size: 0.8rem; margin-top: 0.2rem;"></span>
                    </div>

                    <div style="display: flex; flex-direction: column; gap: 0.4rem;">
                        <label asp-for="Registration.Phone" style="font-size: 0.875rem; font-weight: 600;">@(isDomestic ? "電話" : "Phone")</label>
                        <input type="tel" asp-for="Registration.Phone" autocomplete="tel"
                            placeholder="@(isDomestic ? "選填" : "Optional")"
                            style="padding: 0.65rem 0.875rem; border: 1px solid rgba(0,0,0,0.18); border-radius: 0.5rem; font-size: 0.95rem; font-family: inherit; outline: none; transition: border-color 0.2s; background: transparent; width: 100%; box-sizing: border-box;">
                        <span asp-validation-for="Registration.Phone" style="color:#e53e3e; font-size: 0.8rem; margin-top: 0.2rem;"></span>
                    </div>
                </fieldset>

                <!-- Section 2: Participation -->
                <fieldset style="border: 1px solid rgba(0,0,0,0.12); border-radius: 0.75rem; padding: 1.5rem; margin: 0;">
                    <legend style="font-weight: 700; padding: 0 0.5rem; font-size: 0.875rem; letter-spacing: 0.05em; text-transform: uppercase; opacity: 0.6;">@(isDomestic ? "參與項目" : "Participation")</legend>

                    <div style="display: flex; flex-direction: column; gap: 0.4rem; margin-bottom: 1rem;">
                        <label asp-for="Registration.SightseeingTour" style="font-size: 0.875rem; font-weight: 600;">@(isDomestic ? "觀光行程（九份）" : "Sightseeing Tour (Jiufen)") <span style="color:#e53e3e;">*</span></label>
                        <select asp-for="Registration.SightseeingTour" required
                            style="padding: 0.65rem 0.875rem; border: 1px solid rgba(0,0,0,0.18); border-radius: 0.5rem; font-size: 0.95rem; font-family: inherit; outline: none; transition: border-color 0.2s; background: transparent; width: 100%; box-sizing: border-box; appearance: none; cursor: pointer;">
                            <option value="" disabled selected>@(isDomestic ? "請選擇 是 或 否" : "Select YES or NO")</option>
                            <option value="YES">@(isDomestic ? "是" : "YES")</option>
                            <option value="NO">@(isDomestic ? "否" : "NO")</option>
                        </select>
                        <span asp-validation-for="Registration.SightseeingTour" style="color:#e53e3e; font-size: 0.8rem; margin-top: 0.2rem;"></span>
                    </div>

                    <div style="display: flex; flex-direction: column; gap: 0.4rem;">
                        <label asp-for="Registration.TechnicalTour" style="font-size: 0.875rem; font-weight: 600;">@(isDomestic ? "技術參訪（科技產業）" : "Technical Tour (Technology Industry)") <span style="color:#e53e3e;">*</span></label>
                        <select asp-for="Registration.TechnicalTour" required
                            style="padding: 0.65rem 0.875rem; border: 1px solid rgba(0,0,0,0.18); border-radius: 0.5rem; font-size: 0.95rem; font-family: inherit; outline: none; transition: border-color 0.2s; background: transparent; width: 100%; box-sizing: border-box; appearance: none; cursor: pointer;">
                            <option value="" disabled selected>@(isDomestic ? "請選擇 是 或 否" : "Select YES or NO")</option>
                            <option value="YES">@(isDomestic ? "是" : "YES")</option>
                            <option value="NO">@(isDomestic ? "否" : "NO")</option>
                        </select>
                        <span asp-validation-for="Registration.TechnicalTour" style="color:#e53e3e; font-size: 0.8rem; margin-top: 0.2rem;"></span>
                    </div>
                </fieldset>

                <!-- Section 3: Payment -->
                <fieldset style="border: 1px solid rgba(0,0,0,0.12); border-radius: 0.75rem; padding: 1.5rem; margin: 0;">
                    <legend style="font-weight: 700; padding: 0 0.5rem; font-size: 0.875rem; letter-spacing: 0.05em; text-transform: uppercase; opacity: 0.6;">@(isDomestic ? "付款資訊" : "Payment")</legend>

                    <div style="display: flex; flex-direction: column; gap: 0.4rem; margin-bottom: 1rem;">
                        <label asp-for="Registration.TicketType" style="font-size: 0.875rem; font-weight: 600;">@(isDomestic ? "報名費用類別" : "Registration Fee Category") <span style="color:#e53e3e;">*</span></label>
                        <select asp-for="Registration.TicketType" required
                            style="padding: 0.65rem 0.875rem; border: 1px solid rgba(0,0,0,0.18); border-radius: 0.5rem; font-size: 0.95rem; font-family: inherit; outline: none; transition: border-color 0.2s; background: transparent; width: 100%; box-sizing: border-box; appearance: none; cursor: pointer;">
                            @if (isDomestic)
                            {
                                <option value="" disabled selected>請選擇費用類別</option>
                                <option value="Early Bird">早鳥優惠（2026年8月15日前）— 4,000 TWD</option>
                                <option value="Standard">標準（2026年8月15日後）— 4,500 TWD</option>
                                <option value="Student">學生 — 1,500 TWD</option>
                            }
                            else
                            {
                                <option value="" disabled selected>Select fee category</option>
                                <option value="Early Bird">Early Bird (by 15 August 2026) — 6,000 TWD</option>
                                <option value="Standard">Standard (after 15 August 2026) — 7,500 TWD</option>
                                <option value="Student">Student — 3,000 TWD</option>
                            }
                        </select>
                        <span asp-validation-for="Registration.TicketType" style="color:#e53e3e; font-size: 0.8rem; margin-top: 0.2rem;"></span>
                    </div>

                    <div style="display: flex; flex-direction: column; gap: 0.4rem;">
                        <label asp-for="Registration.PaymentMethod" style="font-size: 0.875rem; font-weight: 600;">@(isDomestic ? "付款方式" : "Payment Method") <span style="color:#e53e3e;">*</span></label>
                        <select asp-for="Registration.PaymentMethod" required
                            style="padding: 0.65rem 0.875rem; border: 1px solid rgba(0,0,0,0.18); border-radius: 0.5rem; font-size: 0.95rem; font-family: inherit; outline: none; transition: border-color 0.2s; background: transparent; width: 100%; box-sizing: border-box; appearance: none; cursor: pointer;">
                            @if (isDomestic)
                            {
                                <option value="" disabled selected>請選擇付款方式</option>
                                <option value="Credit Card">信用卡</option>
                                <option value="Bank Transfer">銀行轉帳</option>
                            }
                            else
                            {
                                <option value="" disabled selected>Select payment method</option>
                                <option value="Credit Card">Credit Card</option>
                                <option value="Bank Transfer">Bank Transfer</option>
                            }
                        </select>
                        <span asp-validation-for="Registration.PaymentMethod" style="color:#e53e3e; font-size: 0.8rem; margin-top: 0.2rem;"></span>
                    </div>
                </fieldset>

                <!-- Agreement -->
                <div style="display: flex; align-items: flex-start; gap: 0.75rem; padding: 1.25rem; border: 1px solid rgba(0,0,0,0.12); border-radius: 0.75rem; flex-direction: column;">
                    <div style="display: flex; align-items: flex-start; gap: 0.75rem;">
                        <input type="checkbox" id="agreement" name="agreement" required @(Request.HasFormContentType && Request.Form["agreement"] == "on" ? "checked" : "") value="on"
                            style="margin-top: 0.15rem; width: 1.1rem; height: 1.1rem; flex-shrink: 0; cursor: pointer; accent-color: var(--accent, #1a73e8);">
                        <label style="font-size: 0.9rem; line-height: 1.5; cursor: pointer;">
                            @if (isDomestic)
                            {
                                @:我已閱讀並同意 ACSEL 2026 的 <button type="button" onclick="openTermsModal()" style="background:none;border:none;padding:0;font:inherit;font-weight:700;color:var(--accent,#1a73e8);cursor:pointer;text-decoration:underline;">報名條款及條件</button>。<span style="color:#e53e3e;">*</span>
                            }
                            else
                            {
                                @:I have read and agree to the <button type="button" onclick="openTermsModal()" style="background:none;border:none;padding:0;font:inherit;font-weight:700;color:var(--accent,#1a73e8);cursor:pointer;text-decoration:underline;">registration terms and conditions</button> of ACSEL 2026. <span style="color:#e53e3e;">*</span>
                            }
                        </label>
                    </div>
                    @if(ModelState["agreement"]?.Errors.Count > 0)
                    {
                        <span style="color:#e53e3e; font-size: 0.8rem; margin-top: 0.2rem;">@ModelState["agreement"]?.Errors[0].ErrorMessage</span>
                    }
                </div>

                <!-- Comments -->
                <div style="display: flex; flex-direction: column; gap: 0.4rem;">
                    <label asp-for="Registration.Comments" style="font-size: 0.875rem; font-weight: 600;">@(isDomestic ? "備註" : "Comments") <span style="opacity:0.5; font-weight:400;">@(isDomestic ? "（選填）" : "(optional)")</span></label>
                    <textarea asp-for="Registration.Comments" rows="3"
                        placeholder="@(isDomestic ? "其他補充資訊" : "Any additional information")"
                        style="padding: 0.65rem 0.875rem; border: 1px solid rgba(0,0,0,0.18); border-radius: 0.5rem; font-size: 0.95rem; font-family: inherit; outline: none; transition: border-color 0.2s; background: transparent; width: 100%; box-sizing: border-box; resize: vertical;"></textarea>
                    <span asp-validation-for="Registration.Comments" style="color:#e53e3e; font-size: 0.8rem; margin-top: 0.2rem;"></span>
                </div>

                <!-- Human Verification -->
                <div style="display: flex; flex-direction: column; gap: 0.4rem; padding: 1.25rem; border: 1px solid rgba(0,0,0,0.12); border-radius: 0.75rem; background: var(--surface-alt, #fafafa);">
                    <label for="CaptchaInput" style="font-size: 0.875rem; font-weight: 600; color: #333;">@(isDomestic ? "圖片驗證" : "Image Verification") <span style="color:#e53e3e;">*</span></label>
                    <p style="font-size: 0.85rem; opacity: 0.7; margin: 0 0 0.5rem 0;">@(isDomestic ? "請輸入圖片中顯示的4位數字。" : "Please enter the 4-digit number shown in the image.")</p>
                    <div style="display: flex; align-items: center; gap: 0.75rem;">
                        <img src="@ViewData["CaptchaImage"]" alt="Captcha Image" style="border-radius: 0.25rem; border: 1px solid #ccc; height: 40px;" />
                        <input type="text" id="CaptchaInput" asp-for="CaptchaInput" required autocomplete="off" maxlength="4" placeholder="Code"
                            style="padding: 0.65rem 0.875rem; border: 1px solid rgba(0,0,0,0.18); border-radius: 0.5rem; font-size: 1rem; font-family: inherit; outline: none; transition: border-color 0.2s; max-width: 100px; box-sizing: border-box;" />
                        <input type="hidden" name="ExpectedCaptcha" value="@Model.ExpectedCaptcha" />
                    </div>
                    <span asp-validation-for="CaptchaInput" style="color:#e53e3e; font-size: 0.8rem; margin-top: 0.2rem;"></span>
                </div>

                <button type="submit" class="btn btn-accent" style="align-self: flex-start; min-width: 200px;">
                    <span class="btn-bg"></span>
                    <span class="btn-text">@(isDomestic ? "送出報名" : "Submit Registration")</span>
                </button>
            </form>
        </div>
    </section>

    <!-- Terms & Conditions Modal -->
    <div id="termsModal" role="dialog" aria-modal="true" aria-labelledby="termsModalTitle"
        style="display:none; position:fixed; inset:0; z-index:9999; background:rgba(0,0,0,0.55); overflow-y:auto; padding: 2rem 1rem;">
        <div style="background:#fff; max-width:640px; margin:auto; border-radius:1rem; padding:2rem 2rem 1.5rem; position:relative; box-shadow:0 24px 48px rgba(0,0,0,0.18);">
            <button type="button" onclick="closeTermsModal(false)" aria-label="Close"
                style="position:absolute; top:1rem; right:1rem; background:none; border:none; cursor:pointer; font-size:1.4rem; line-height:1; opacity:0.5;">&#x2715;</button>

            <h2 id="termsModalTitle" style="font-size:1.35rem; font-weight:700; margin:0 0 0.25rem;">Agreement &amp; Consent</h2>
            <p style="font-size:0.875rem; opacity:0.6; margin:0 0 1.5rem;">Please read the following registration terms and conditions carefully.</p>

            <div style="font-size:0.9rem; line-height:1.7; max-height:55vh; overflow-y:auto; padding-right:0.5rem;">
                <h3 style="font-size:1rem; font-weight:700; margin:0 0 0.4rem;">1. Registration Confirmation</h3>
                <p style="margin:0 0 1rem; opacity:0.8;">Registration is confirmed only after full payment of the applicable registration fee.</p>

                <h3 style="font-size:1rem; font-weight:700; margin:0 0 0.4rem;">2. Attendance &amp; Participation</h3>
                <p style="margin:0 0 0.4rem; opacity:0.8;">Participants are responsible for their own travel, accommodation, and visa arrangements.</p>
                <p style="margin:0 0 1rem; opacity:0.8;">The conference organizers reserve the right to make changes to the program, speakers, or schedule.</p>

                <h3 style="font-size:1rem; font-weight:700; margin:0 0 0.4rem;">3. Intellectual Property</h3>
                <p style="margin:0 0 0.4rem; opacity:0.8;">Submitted papers, abstracts, and presentations must be original work.</p>
                <p style="margin:0 0 1rem; opacity:0.8;">Authors retain copyright but grant ACSEL the right to publish abstracts or papers in conference proceedings.</p>

                <h3 style="font-size:1rem; font-weight:700; margin:0 0 0.4rem;">4. Privacy &amp; Data Protection</h3>
                <p style="margin:0 0 0.4rem; opacity:0.8;">Personal information collected for registration will only be used for conference administration and communication.</p>
                <p style="margin:0 0 1rem; opacity:0.8;">All information will be handled in accordance with applicable data protection regulations.</p>

                <h3 style="font-size:1rem; font-weight:700; margin:0 0 0.4rem;">5. Agreement</h3>
                <p style="margin:0 0 1.5rem; opacity:0.8;">By registering, participants agree to comply with the above terms and conditions.</p>
            </div>

            <div style="display:flex; gap:0.75rem; justify-content:flex-end; margin-top:1.25rem; padding-top:1.25rem; border-top:1px solid rgba(0,0,0,0.1);">
                <button type="button" onclick="closeTermsModal(false)"
                    style="padding:0.6rem 1.25rem; border:1px solid rgba(0,0,0,0.18); border-radius:0.5rem; background:transparent; font:inherit; font-size:0.9rem; cursor:pointer;">Cancel</button>
                <button type="button" onclick="closeTermsModal(true)" class="btn btn-accent" style="min-width:130px;">
                    <span class="btn-bg"></span>
                    <span class="btn-text">I Agree</span>
                </button>
            </div>
        </div>
    </div>

    <script>
        // Focus border highlight
        document.querySelectorAll('#registrationForm input, #registrationForm select, #registrationForm textarea').forEach(function(el) {
            el.addEventListener('focus', function() { el.style.borderColor = 'var(--accent, #1a73e8)'; });
            el.addEventListener('blur', function() { el.style.borderColor = 'rgba(0,0,0,0.18)'; });
        });

        // Intercept checkbox click to show modal
        var agreementCheckbox = document.getElementById('agreement');
        agreementCheckbox.addEventListener('click', function (e) {
            if (this.checked) {
                this.checked = false;
                openTermsModal();
            }
        });

        function openTermsModal() {
            document.getElementById('termsModal').style.display = 'block';
            document.body.style.overflow = 'hidden';
        }

        function closeTermsModal(agreed) {
            document.getElementById('termsModal').style.display = 'none';
            document.body.style.overflow = '';
            if (agreed) {
                agreementCheckbox.checked = true;
            }
        }

        // Close on backdrop click
        document.getElementById('termsModal').addEventListener('click', function (e) {
            if (e.target === this) closeTermsModal(false);
        });

        // Close on Escape key
        document.addEventListener('keydown', function (e) {
            if (e.key === 'Escape' && document.getElementById('termsModal').style.display === 'block') {
                closeTermsModal(false);
            }
        });
    </script>

    <footer class="footer">
        <div class="container footer-grid">
            <div class="footer-brand">
                <h2>ACSEL 2026</h2>
                <p>The 13th Asian Conference on Safety & Education in Laboratory</p>
                <div class="system-status mt-md">
                    <span class="material-symbols-outlined status-dot">fiber_manual_record</span>
                    <span class="status-text data-text">System Operational // Registration Open</span>
                </div>
            </div>
            <div class="footer-nav">
                <h4>Information</h4>
                <a href="~/about.html">About</a>
                <a href="~/programme.html">Programme</a>
                <a href="~/speakers.html">Speakers</a>
                <a href="~/travel.html">Travel</a>
                <a href="~/sponsorship.html">Sponsorship</a>
                <a href="~/submit.html">Submit</a>
                <a href="~/Register">Registration</a>
            </div>
        </div>
    </footer>

    <script src="~/main.js"></script>

    @await Html.PartialAsync("Shared/_ValidationScriptsPartial")
</body>
</html>
