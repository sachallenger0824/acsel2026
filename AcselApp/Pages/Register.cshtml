@page
@model AcselApp.Pages.RegisterModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Registration | ACSEL 2026</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@1,600&family=IBM+Plex+Mono&family=Outfit:wght@400;600&family=Plus+Jakarta+Sans:wght@400;700&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined" rel="stylesheet">
    <link rel="stylesheet" href="~/style.css">
</head>
<body>
    <svg class="noise-overlay" viewBox="0 0 100 100" preserveAspectRatio="none">
        <filter id="noiseFilter">
            <feTurbulence type="fractalNoise" baseFrequency="0.8" numOctaves="3" stitchTiles="stitch" />
        </filter>
        <rect width="100%" height="100%" filter="url(#noiseFilter)" opacity="0.05" />
    </svg>

    <nav class="navbar" id="navbar">
        <div class="nav-container">
            <a href="~/" class="logo">ACSEL 2026</a>
            <input type="checkbox" id="nav-toggle" class="nav-toggle-checkbox">
            <label for="nav-toggle" class="nav-toggle-label">
                <span class="material-symbols-outlined menu-icon">menu</span>
                <span class="material-symbols-outlined close-icon">close</span>
            </label>
            <div class="nav-menu">
                <a href="~/about.html" class="nav-link">About</a>
                <a href="~/programme.html" class="nav-link">Programme</a>
                <a href="~/speakers.html" class="nav-link">Speakers</a>
                <a href="~/travel.html" class="nav-link">Travel</a>
                <a href="~/sponsorship.html" class="nav-link">Sponsorship</a>
                <a href="~/submit.html" class="nav-link" style="white-space:nowrap;">Submit Paper</a>
                <a href="~/Register" class="btn btn-accent nav-cta">
                    <span class="btn-bg"></span>
                    <span class="btn-text">Register</span>
                </a>
            </div>
        </div>
    </nav>

    <section class="hero subpage-hero section-dark">
        <div class="hero-bg"></div>
        <div class="hero-gradient"></div>
        <div class="container hero-container" style="padding-top: 15vh;">
            <div class="hero-content">
                <h1 class="hero-title animate-item">
                    <span class="hero-serif">Registration</span>
                </h1>
            </div>
        </div>
    </section>

    <section id="register" class="registration-section container py-fluid pb-xxl">
        <p class="text-center mb-xl animate-on-scroll">Secure your spot for ACSEL 2026.</p>

        @if (!string.IsNullOrEmpty(Model.SuccessMessage))
        {
            <div class="animate-on-scroll" style="background: rgba(40, 167, 69, 0.15); border: 1px solid rgba(40, 167, 69, 0.4); padding: 1.5rem; border-radius: 1rem; text-align: center; margin-bottom: 2rem; color: #28a745;">
                <span class="material-symbols-outlined" style="vertical-align: middle;">check_circle</span>
                <strong>@Model.SuccessMessage</strong>
            </div>
        }

        <div class="pricing-grid animate-on-scroll">
            <div class="pricing-card">
                <h3>Early Bird</h3>
                <p class="ends data-text">Ends 15 August 2026</p>
                <div class="price">4,000 <span class="currency">TWD</span></div>
                <p class="tier">Standard</p>
            </div>
            <div class="pricing-card featured">
                <h3>Standard</h3>
                <p class="ends data-text">After 15 August 2026</p>
                <div class="price">4,500 <span class="currency">TWD</span></div>
                <p class="tier">Standard</p>
            </div>
            <div class="pricing-card">
                <h3>Student</h3>
                <p class="ends data-text">Valid Student ID Required</p>
                <div class="price">1,500 <span class="currency">TWD</span></div>
                <p class="tier">Student (Early / Standard)</p>
            </div>
        </div>
    </section>

    <!-- Registration Form Section -->
    <section class="container pb-xxl" style="padding-top: 0; max-width: 720px;">
        <div class="animate-on-scroll">
            <h2 style="font-size: 1.75rem; font-weight: 700; margin-bottom: 0.5rem;">Registration Form</h2>
            <p style="opacity: 0.65; margin-bottom: 2.5rem;">Please fill in all required fields to complete your registration.</p>

            <form id="registrationForm" method="post" novalidate
                style="display: flex; flex-direction: column; gap: 1.5rem;">
                @Html.AntiForgeryToken()

                <!-- Section 1: Personal Information -->
                <fieldset style="border: 1px solid rgba(0,0,0,0.12); border-radius: 0.75rem; padding: 1.5rem; margin: 0;">
                    <legend style="font-weight: 700; padding: 0 0.5rem; font-size: 0.875rem; letter-spacing: 0.05em; text-transform: uppercase; opacity: 0.6;">Personal Information</legend>

                    <div style="display: flex; flex-direction: column; gap: 0.4rem; margin-bottom: 1rem;">
                        <label for="FullName" style="font-size: 0.875rem; font-weight: 600;">Full Name (First / Last) <span style="color:#e53e3e;">*</span></label>
                        <input type="text" id="FullName" name="Registration.FullName" required autocomplete="name"
                            placeholder="Full Name"
                            style="padding: 0.65rem 0.875rem; border: 1px solid rgba(0,0,0,0.18); border-radius: 0.5rem; font-size: 0.95rem; font-family: inherit; outline: none; transition: border-color 0.2s; background: transparent; width: 100%; box-sizing: border-box;">
                    </div>

                    <div style="display: flex; flex-direction: column; gap: 0.4rem; margin-bottom: 1rem;">
                        <label for="Email" style="font-size: 0.875rem; font-weight: 600;">Email Address <span style="color:#e53e3e;">*</span></label>
                        <input type="email" id="Email" name="Registration.Email" required autocomplete="email"
                            placeholder="your@email.com"
                            style="padding: 0.65rem 0.875rem; border: 1px solid rgba(0,0,0,0.18); border-radius: 0.5rem; font-size: 0.95rem; font-family: inherit; outline: none; transition: border-color 0.2s; background: transparent; width: 100%; box-sizing: border-box;">
                    </div>

                    <div style="display: flex; flex-direction: column; gap: 0.4rem; margin-bottom: 1rem;">
                        <label for="Institution" style="font-size: 0.875rem; font-weight: 600;">Affiliation / Organization <span style="color:#e53e3e;">*</span></label>
                        <input type="text" id="Institution" name="Registration.Institution" required autocomplete="organization"
                            placeholder="Institution or organization name"
                            style="padding: 0.65rem 0.875rem; border: 1px solid rgba(0,0,0,0.18); border-radius: 0.5rem; font-size: 0.95rem; font-family: inherit; outline: none; transition: border-color 0.2s; background: transparent; width: 100%; box-sizing: border-box;">
                    </div>

                    <div style="display: flex; flex-direction: column; gap: 0.4rem; margin-bottom: 1rem;">
                        <label for="TitlePosition" style="font-size: 0.875rem; font-weight: 600;">Title / Position <span style="color:#e53e3e;">*</span></label>
                        <input type="text" id="TitlePosition" name="Registration.TitlePosition" required
                            placeholder="e.g. Professor, Researcher, Student"
                            style="padding: 0.65rem 0.875rem; border: 1px solid rgba(0,0,0,0.18); border-radius: 0.5rem; font-size: 0.95rem; font-family: inherit; outline: none; transition: border-color 0.2s; background: transparent; width: 100%; box-sizing: border-box;">
                    </div>

                    <div style="display: flex; flex-direction: column; gap: 0.4rem;">
                        <label for="Phone" style="font-size: 0.875rem; font-weight: 600;">Phone</label>
                        <input type="tel" id="Phone" name="Registration.Phone" autocomplete="tel"
                            placeholder="Optional"
                            style="padding: 0.65rem 0.875rem; border: 1px solid rgba(0,0,0,0.18); border-radius: 0.5rem; font-size: 0.95rem; font-family: inherit; outline: none; transition: border-color 0.2s; background: transparent; width: 100%; box-sizing: border-box;">
                    </div>
                </fieldset>

                <!-- Section 2: Participation -->
                <fieldset style="border: 1px solid rgba(0,0,0,0.12); border-radius: 0.75rem; padding: 1.5rem; margin: 0;">
                    <legend style="font-weight: 700; padding: 0 0.5rem; font-size: 0.875rem; letter-spacing: 0.05em; text-transform: uppercase; opacity: 0.6;">Participation</legend>

                    <div style="display: flex; flex-direction: column; gap: 0.4rem; margin-bottom: 1rem;">
                        <label for="ParticipationType" style="font-size: 0.875rem; font-weight: 600;">Participation Type <span style="color:#e53e3e;">*</span></label>
                        <select id="ParticipationType" name="Registration.ParticipationType" required
                            style="padding: 0.65rem 0.875rem; border: 1px solid rgba(0,0,0,0.18); border-radius: 0.5rem; font-size: 0.95rem; font-family: inherit; outline: none; transition: border-color 0.2s; background: transparent; width: 100%; box-sizing: border-box; appearance: none; cursor: pointer;">
                            <option value="" disabled selected>Select participation type</option>
                            <option value="Oral Presentation">Oral Presentation</option>
                            <option value="Poster Presentation">Poster Presentation</option>
                            <option value="Attendee">Attendee</option>
                            <option value="Student">Student</option>
                        </select>
                    </div>

                    <div style="display: flex; flex-direction: column; gap: 0.4rem; margin-bottom: 1rem;">
                        <label for="PaperTitle" style="font-size: 0.875rem; font-weight: 600;">Paper / Poster Title <span style="opacity:0.5; font-weight:400;">(if applicable)</span></label>
                        <input type="text" id="PaperTitle" name="Registration.PaperTitle"
                            placeholder="Leave blank if attending only"
                            style="padding: 0.65rem 0.875rem; border: 1px solid rgba(0,0,0,0.18); border-radius: 0.5rem; font-size: 0.95rem; font-family: inherit; outline: none; transition: border-color 0.2s; background: transparent; width: 100%; box-sizing: border-box;">
                    </div>

                    <div style="display: flex; flex-direction: column; gap: 0.4rem; margin-bottom: 1rem;">
                        <label for="SightseeingTour" style="font-size: 0.875rem; font-weight: 600;">Sightseeing Tour (Jiufen) <span style="color:#e53e3e;">*</span></label>
                        <select id="SightseeingTour" name="Registration.SightseeingTour" required
                            style="padding: 0.65rem 0.875rem; border: 1px solid rgba(0,0,0,0.18); border-radius: 0.5rem; font-size: 0.95rem; font-family: inherit; outline: none; transition: border-color 0.2s; background: transparent; width: 100%; box-sizing: border-box; appearance: none; cursor: pointer;">
                            <option value="" disabled selected>Select YES or NO</option>
                            <option value="YES">YES</option>
                            <option value="NO">NO</option>
                        </select>
                    </div>

                    <div style="display: flex; flex-direction: column; gap: 0.4rem;">
                        <label for="TechnicalTour" style="font-size: 0.875rem; font-weight: 600;">Technical Tour (Technology Industry) <span style="color:#e53e3e;">*</span></label>
                        <select id="TechnicalTour" name="Registration.TechnicalTour" required
                            style="padding: 0.65rem 0.875rem; border: 1px solid rgba(0,0,0,0.18); border-radius: 0.5rem; font-size: 0.95rem; font-family: inherit; outline: none; transition: border-color 0.2s; background: transparent; width: 100%; box-sizing: border-box; appearance: none; cursor: pointer;">
                            <option value="" disabled selected>Select YES or NO</option>
                            <option value="YES">YES</option>
                            <option value="NO">NO</option>
                        </select>
                    </div>
                </fieldset>

                <!-- Section 3: Payment -->
                <fieldset style="border: 1px solid rgba(0,0,0,0.12); border-radius: 0.75rem; padding: 1.5rem; margin: 0;">
                    <legend style="font-weight: 700; padding: 0 0.5rem; font-size: 0.875rem; letter-spacing: 0.05em; text-transform: uppercase; opacity: 0.6;">Payment</legend>

                    <div style="display: flex; flex-direction: column; gap: 0.4rem; margin-bottom: 1rem;">
                        <label for="TicketType" style="font-size: 0.875rem; font-weight: 600;">Registration Fee Category <span style="color:#e53e3e;">*</span></label>
                        <select id="TicketType" name="Registration.TicketType" required
                            style="padding: 0.65rem 0.875rem; border: 1px solid rgba(0,0,0,0.18); border-radius: 0.5rem; font-size: 0.95rem; font-family: inherit; outline: none; transition: border-color 0.2s; background: transparent; width: 100%; box-sizing: border-box; appearance: none; cursor: pointer;">
                            <option value="" disabled selected>Select fee category</option>
                            <option value="Early Bird">Early Bird (by 15 August 2026) — 4,000 TWD</option>
                            <option value="Standard">Standard (after 15 August 2026) — 4,500 TWD</option>
                            <option value="Student">Student — 1,500 TWD</option>
                        </select>
                    </div>

                    <div style="display: flex; flex-direction: column; gap: 0.4rem;">
                        <label for="PaymentMethod" style="font-size: 0.875rem; font-weight: 600;">Payment Method <span style="color:#e53e3e;">*</span></label>
                        <select id="PaymentMethod" name="Registration.PaymentMethod" required
                            style="padding: 0.65rem 0.875rem; border: 1px solid rgba(0,0,0,0.18); border-radius: 0.5rem; font-size: 0.95rem; font-family: inherit; outline: none; transition: border-color 0.2s; background: transparent; width: 100%; box-sizing: border-box; appearance: none; cursor: pointer;">
                            <option value="" disabled selected>Select payment method</option>
                            <option value="Credit Card">Credit Card</option>
                            <option value="Bank Transfer">Bank Transfer</option>
                        </select>
                    </div>
                </fieldset>

                <!-- Agreement -->
                <div style="display: flex; align-items: flex-start; gap: 0.75rem; padding: 1.25rem; border: 1px solid rgba(0,0,0,0.12); border-radius: 0.75rem;">
                    <input type="checkbox" id="agreement" name="agreement" required
                        style="margin-top: 0.15rem; width: 1.1rem; height: 1.1rem; flex-shrink: 0; cursor: pointer; accent-color: var(--accent, #1a73e8);">
                    <label style="font-size: 0.9rem; line-height: 1.5; cursor: pointer;">
                        I have read and agree to the <button type="button" onclick="openTermsModal()" style="background:none;border:none;padding:0;font:inherit;font-weight:700;color:var(--accent,#1a73e8);cursor:pointer;text-decoration:underline;">registration terms and conditions</button> of ACSEL 2026. <span style="color:#e53e3e;">*</span>
                    </label>
                </div>

                <!-- Comments -->
                <div style="display: flex; flex-direction: column; gap: 0.4rem;">
                    <label for="Comments" style="font-size: 0.875rem; font-weight: 600;">Comments <span style="opacity:0.5; font-weight:400;">(optional)</span></label>
                    <textarea id="Comments" name="Registration.Comments" rows="3"
                        placeholder="Any additional information"
                        style="padding: 0.65rem 0.875rem; border: 1px solid rgba(0,0,0,0.18); border-radius: 0.5rem; font-size: 0.95rem; font-family: inherit; outline: none; transition: border-color 0.2s; background: transparent; width: 100%; box-sizing: border-box; resize: vertical;"></textarea>
                </div>

                <button type="submit" class="btn btn-accent" style="align-self: flex-start; min-width: 200px;">
                    <span class="btn-bg"></span>
                    <span class="btn-text">Submit Registration</span>
                </button>
            </form>
        </div>
    </section>

    <!-- Terms & Conditions Modal -->
    <div id="termsModal" role="dialog" aria-modal="true" aria-labelledby="termsModalTitle"
        style="display:none; position:fixed; inset:0; z-index:9999; background:rgba(0,0,0,0.55); overflow-y:auto; padding: 2rem 1rem;">
        <div style="background:#fff; max-width:640px; margin:auto; border-radius:1rem; padding:2rem 2rem 1.5rem; position:relative; box-shadow:0 24px 48px rgba(0,0,0,0.18);">
            <button type="button" onclick="closeTermsModal(false)" aria-label="Close"
                style="position:absolute; top:1rem; right:1rem; background:none; border:none; cursor:pointer; font-size:1.4rem; line-height:1; opacity:0.5;">&#x2715;</button>

            <h2 id="termsModalTitle" style="font-size:1.35rem; font-weight:700; margin:0 0 0.25rem;">Agreement &amp; Consent</h2>
            <p style="font-size:0.875rem; opacity:0.6; margin:0 0 1.5rem;">Please read the following registration terms and conditions carefully.</p>

            <div style="font-size:0.9rem; line-height:1.7; max-height:55vh; overflow-y:auto; padding-right:0.5rem;">
                <h3 style="font-size:1rem; font-weight:700; margin:0 0 0.4rem;">1. Registration Confirmation</h3>
                <p style="margin:0 0 1rem; opacity:0.8;">Registration is confirmed only after full payment of the applicable registration fee.</p>

                <h3 style="font-size:1rem; font-weight:700; margin:0 0 0.4rem;">2. Attendance &amp; Participation</h3>
                <p style="margin:0 0 0.4rem; opacity:0.8;">Participants are responsible for their own travel, accommodation, and visa arrangements.</p>
                <p style="margin:0 0 1rem; opacity:0.8;">The conference organizers reserve the right to make changes to the program, speakers, or schedule.</p>

                <h3 style="font-size:1rem; font-weight:700; margin:0 0 0.4rem;">3. Intellectual Property</h3>
                <p style="margin:0 0 0.4rem; opacity:0.8;">Submitted papers, abstracts, and presentations must be original work.</p>
                <p style="margin:0 0 1rem; opacity:0.8;">Authors retain copyright but grant ACSEL the right to publish abstracts or papers in conference proceedings.</p>

                <h3 style="font-size:1rem; font-weight:700; margin:0 0 0.4rem;">4. Privacy &amp; Data Protection</h3>
                <p style="margin:0 0 0.4rem; opacity:0.8;">Personal information collected for registration will only be used for conference administration and communication.</p>
                <p style="margin:0 0 1rem; opacity:0.8;">All information will be handled in accordance with applicable data protection regulations.</p>

                <h3 style="font-size:1rem; font-weight:700; margin:0 0 0.4rem;">5. Agreement</h3>
                <p style="margin:0 0 1.5rem; opacity:0.8;">By registering, participants agree to comply with the above terms and conditions.</p>
            </div>

            <div style="display:flex; gap:0.75rem; justify-content:flex-end; margin-top:1.25rem; padding-top:1.25rem; border-top:1px solid rgba(0,0,0,0.1);">
                <button type="button" onclick="closeTermsModal(false)"
                    style="padding:0.6rem 1.25rem; border:1px solid rgba(0,0,0,0.18); border-radius:0.5rem; background:transparent; font:inherit; font-size:0.9rem; cursor:pointer;">Cancel</button>
                <button type="button" onclick="closeTermsModal(true)" class="btn btn-accent" style="min-width:130px;">
                    <span class="btn-bg"></span>
                    <span class="btn-text">I Agree</span>
                </button>
            </div>
        </div>
    </div>

    <script>
        // Focus border highlight
        document.querySelectorAll('#registrationForm input, #registrationForm select, #registrationForm textarea').forEach(function(el) {
            el.addEventListener('focus', function() { el.style.borderColor = 'var(--accent, #1a73e8)'; });
            el.addEventListener('blur', function() { el.style.borderColor = 'rgba(0,0,0,0.18)'; });
        });

        // Intercept checkbox click to show modal
        var agreementCheckbox = document.getElementById('agreement');
        agreementCheckbox.addEventListener('click', function (e) {
            if (this.checked) {
                this.checked = false;
                openTermsModal();
            }
        });

        function openTermsModal() {
            document.getElementById('termsModal').style.display = 'block';
            document.body.style.overflow = 'hidden';
        }

        function closeTermsModal(agreed) {
            document.getElementById('termsModal').style.display = 'none';
            document.body.style.overflow = '';
            if (agreed) {
                agreementCheckbox.checked = true;
            }
        }

        // Close on backdrop click
        document.getElementById('termsModal').addEventListener('click', function (e) {
            if (e.target === this) closeTermsModal(false);
        });

        // Close on Escape key
        document.addEventListener('keydown', function (e) {
            if (e.key === 'Escape' && document.getElementById('termsModal').style.display === 'block') {
                closeTermsModal(false);
            }
        });
    </script>

    <footer class="footer">
        <div class="container footer-grid">
            <div class="footer-brand">
                <h2>ACSEL 2026</h2>
                <p>The 13th Asian Conference on Safety & Education in Laboratory</p>
                <div class="system-status mt-md">
                    <span class="material-symbols-outlined status-dot">fiber_manual_record</span>
                    <span class="status-text data-text">System Operational // Registration Open</span>
                </div>
            </div>
            <div class="footer-nav">
                <h4>Information</h4>
                <a href="~/about.html">About</a>
                <a href="~/programme.html">Programme</a>
                <a href="~/speakers.html">Speakers</a>
                <a href="~/travel.html">Travel</a>
                <a href="~/sponsorship.html">Sponsorship</a>
                <a href="~/submit.html">Submit</a>
                <a href="~/Register">Registration</a>
            </div>
        </div>
    </footer>

    <script src="~/main.js"></script>
</body>
</html>
